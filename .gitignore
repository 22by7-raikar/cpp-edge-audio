# C++ build artifacts
runtime/cpp/build/
*.o
*.a
*.so

# Model files
*.bin
*.gguf
*.pt
*.onnx

# Dataset directories — tracked by structure (.gitkeep) and symlinks, not content
data/raw/*
!data/raw/.gitkeep
!data/raw/librispeech
!data/raw/musan
!data/raw/rirs_noises
!data/raw/demand_16k
data/external/*
!data/external/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/tmp/*
!data/tmp/.gitkeep
# manifests and labels are small text files — commit them
# but ignore auto-generated chunks
data/manifests/chunks_*.tsv
data/labels/auto_*.tsv

# Legacy ignore (pre-restructure)
data/*.wav
data/*.flac

# Benchmark results (keep configs, gitignore raw output logs)
benchmarks/results/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
tools/python/edge_stt/

# Editor / OS
.DS_Store
.vscode/settings.json
*.swp
