# C++ build artifacts
runtime/cpp/build/
*.o
*.a
*.so

# Model files
*.bin
*.gguf
*.pt
*.onnx

# Dataset directories — tracked by structure (.gitkeep) and symlinks, not content
data/raw/*
!data/raw/.gitkeep
data/external/*
!data/external/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/tmp/*
!data/tmp/.gitkeep
# manifests and labels are small text files — commit them
# but ignore auto-generated chunks
data/manifests/chunks_*.tsv
data/labels/auto_*.tsv

# Legacy ignore (pre-restructure)
data/*.wav
data/*.flac

# All generated C++ build trees
runtime/cpp/build_tests/

# Local repository archives and diagnostics
cpp-edge-audio-src.tar.gz
missing_paths.txt

# Local agent prompts and workspace settings
prompts/
*.code-workspace

# Benchmark results (keep configs, gitignore raw output logs)
benchmarks/results/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
tools/python/edge_stt/

# Editor / OS
.DS_Store
.vscode/settings.json
*.swp
*.save
